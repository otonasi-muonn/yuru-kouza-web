# ------------------------------------------------------------
# yuruhack-site（React + TypeScript + Vite）用 .gitignore
# ルートの .gitignore で拾えないプロジェクト固有のものを追記。
# ------------------------------------------------------------

# --- ログ ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 依存 / ビルド ---
node_modules
.pnpm-store/
dist
dist-ssr
*.local

# Parcel（単一 HTML バンドル用）のキャッシュと中間成果物
.parcel-cache/

# 単一 HTML バンドル（`pnpm exec html-inline` の出力）
# 配布するときはリポジトリルートの yuruhack-docs.html をコミットする運用なので、
# ここで生成される bundle.html は追跡しない。
bundle.html

# --- TypeScript インクリメンタルビルド情報 ---
# （tsBuildInfoFile を node_modules/.tmp に向けているが、
#   念のためルート配置にも備えてパターンで弾く）
*.tsbuildinfo

# --- テスト / カバレッジ ---
coverage/
.vitest-cache/
.nyc_output/

# --- 環境変数 ---
.env
.env.*
!.env.example

# --- エディタ / IDE / OS ---
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
